<% if resource.errors.any? %>
  <div id="error_explanation" data-turbo-temporary style="background-color: #fdf2e9; border-left: 4px solid #e74c3c; border-radius: 5px; padding: 15px; margin-bottom: 20px; color: #922b21;">
    <h2 style="margin: 0 0 10px 0; font-size: 1em;">
      <%= resource.errors.count %>件のエラーがあります。更新できませんでした。
    </h2>
    <ul style="margin: 0; padding-left: 20px;">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
